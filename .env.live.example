# Alpaca live credentials
ALPACA_API_KEY=your-live-alpaca-api-key
ALPACA_SECRET_KEY=your-live-alpaca-secret-key
ALPACA_PAPER=false
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_FEED=iex

# Live execution mode
DRY_RUN=false
PAPER_ONLY=false
ALLOW_LIVE=true
CONFIG_PROFILE=live
LIVE_CONFIG_PROFILE=live
LIVE_DEPLOYMENT_ACK=I_ACKNOWLEDGE_LIVE_TRADING
PRIMARY_LIVE_STRATEGY=breakout

# Use a dedicated live journal.
DATABASE_URL=sqlite:///trading_live.db
LOG_LEVEL=INFO

# Start smaller than paper.
SYMBOLS=SPY,QQQ,IWM,AAPL,MSFT
MAX_POSITIONS=2
MAX_SYMBOLS_PER_RUN=2
MAX_POSITION_NOTIONAL=2500
MAX_GROSS_EXPOSURE=5000
MAX_SYMBOL_EXPOSURE=2500
MIN_CASH_BUFFER=2500
MAX_DAILY_LOSS=250
MAX_UNREALIZED_DRAWDOWN=350
EMERGENCY_UNREALIZED_DRAWDOWN=500
MAX_ORDER_QTY=10
MAX_OPEN_ORDERS=2
MAX_STUCK_ORDER_MINUTES=15
MAX_BROKER_FAILURES=2
RISK_PER_TRADE_FRACTION=0.0025

# Shared data and liquidity settings
LOOKBACK_DAYS=400
MIN_HISTORY_DAYS=120
MIN_AVERAGE_DAILY_VOLUME=1000000
BACKTEST_OUT_OF_SAMPLE_FRACTION=0.3
BACKTEST_WALK_FORWARD_TRAIN_DAYS=126
BACKTEST_WALK_FORWARD_TEST_DAYS=63
BACKTEST_MIN_CLOSED_TRADES=3
BACKTEST_MAX_OUT_OF_SAMPLE_DRAWDOWN=0.20
BACKTEST_OUTPUT_DIR=artifacts/backtests

# Breakout is the default live candidate.
TREND_WINDOW=100
EXIT_WINDOW=50
ATR_WINDOW=14
ATR_RISK_BUDGET=100
MAX_ATR_RATIO=0.08
BREAKOUT_ENTRY_WINDOW=55
BREAKOUT_EXIT_WINDOW=20
BREAKOUT_ATR_WINDOW=20

# Safety controls
ALLOW_UNSAFE_DATA_FALLBACK=false
ALLOW_PARTIAL_MARKET_DATA=false
FORCE_EXIT_SYMBOLS=
EMERGENCY_FLATTEN=false
DENY_NEW_ENTRIES=true

# Alerts must be configured before go-live.
ALERT_WEBHOOK_URL=https://example.com/replace-with-real-webhook
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_ON_BLOCKED_ORDERS=true
ALERT_ON_RECONCILIATION_DRIFT=true
ALERT_ON_DRAWDOWN_BREACH=true
ALERT_ON_STALE_DATA=true

# Safe-open restricts new live entries to an operator-watched window.
SAFE_OPEN_ENABLED=true
SAFE_OPEN_START_TIME=09:35
SAFE_OPEN_END_TIME=10:30

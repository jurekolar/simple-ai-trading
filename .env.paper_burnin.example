# Alpaca credentials
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex

# Burn-in should submit real paper orders, not dry-run only.
DRY_RUN=false
PAPER_ONLY=true
ALLOW_LIVE=false
CONFIG_PROFILE=paper
LIVE_CONFIG_PROFILE=
LIVE_DEPLOYMENT_ACK=
PRIMARY_LIVE_STRATEGY=breakout

# Keep burn-in journal isolated from any existing local history.
DATABASE_URL=sqlite:///trading_burnin.db
LOG_LEVEL=INFO

# Start narrow. Expand only after stable burn-in behavior.
SYMBOLS=SPY,IWM,EFA,EEM,EWZ,XLF,KRE,AMZN,NVDA,BAC,QQQ,AAPL,MSFT,META,AMD,GOOGL,AVGO,TSLA,ORCL
MAX_POSITIONS=3
MAX_SYMBOLS_PER_RUN=2
MAX_POSITION_NOTIONAL=5000
MAX_GROSS_EXPOSURE=15000
MAX_SYMBOL_EXPOSURE=5000
MIN_CASH_BUFFER=1000
MAX_DAILY_LOSS=500
MAX_UNREALIZED_DRAWDOWN=750
EMERGENCY_UNREALIZED_DRAWDOWN=1250
MAX_ORDER_QTY=25
MAX_OPEN_ORDERS=4
MAX_STUCK_ORDER_MINUTES=20
MAX_BROKER_FAILURES=3
RISK_PER_TRADE_FRACTION=0.005

# Shared data and liquidity settings
LOOKBACK_DAYS=400
MIN_HISTORY_DAYS=120
MIN_AVERAGE_DAILY_VOLUME=1000000

# Momentum strategy settings
TREND_WINDOW=100
EXIT_WINDOW=50
ATR_WINDOW=14
ATR_RISK_BUDGET=100
MAX_ATR_RATIO=0.08

# Mean reversion strategy settings
MEAN_REVERSION_WINDOW=20
MEAN_REVERSION_VOLATILITY_WINDOW=20
MEAN_REVERSION_ENTRY_ZSCORE=-1.0
MEAN_REVERSION_EXIT_ZSCORE=0.0

# Breakout strategy settings
BREAKOUT_ENTRY_WINDOW=55
BREAKOUT_EXIT_WINDOW=20
BREAKOUT_ATR_WINDOW=20

# Safety controls
ALLOW_UNSAFE_DATA_FALLBACK=false
ALLOW_PARTIAL_MARKET_DATA=false
FORCE_EXIT_SYMBOLS=
EMERGENCY_FLATTEN=false
DENY_NEW_ENTRIES=false

# Alerts
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_ON_BLOCKED_ORDERS=true
ALERT_ON_RECONCILIATION_DRIFT=true
ALERT_ON_DRAWDOWN_BREACH=true
ALERT_ON_STALE_DATA=true

# Live rollout guardrail is disabled during paper burn-in.
SAFE_OPEN_ENABLED=false
SAFE_OPEN_START_TIME=09:35
SAFE_OPEN_END_TIME=10:30

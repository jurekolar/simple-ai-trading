# Alpaca credentials
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex

# Execution mode
DRY_RUN=true
PAPER_ONLY=true
ALLOW_LIVE=false
CONFIG_PROFILE=paper
LIVE_CONFIG_PROFILE=
LIVE_DEPLOYMENT_ACK=
PRIMARY_LIVE_STRATEGY=breakout

# Persistence and logging
DATABASE_URL=sqlite:///trading.db
LOG_LEVEL=INFO

# Universe and portfolio limits
SYMBOLS=SPY,QQQ,IWM,AAPL,MSFT
MAX_POSITIONS=3
MAX_SYMBOLS_PER_RUN=3
MAX_POSITION_NOTIONAL=20000
MAX_GROSS_EXPOSURE=50000
MAX_SYMBOL_EXPOSURE=20000
MIN_CASH_BUFFER=0
MAX_DAILY_LOSS=1000
MAX_UNREALIZED_DRAWDOWN=1500
EMERGENCY_UNREALIZED_DRAWDOWN=2500
MAX_ORDER_QTY=25
MAX_OPEN_ORDERS=8
MAX_STUCK_ORDER_MINUTES=20
MAX_BROKER_FAILURES=3
RISK_PER_TRADE_FRACTION=0.01

# Shared data and liquidity settings
LOOKBACK_DAYS=400
MIN_HISTORY_DAYS=120
MIN_AVERAGE_DAILY_VOLUME=500000
BACKTEST_OUT_OF_SAMPLE_FRACTION=0.3
BACKTEST_WALK_FORWARD_TRAIN_DAYS=126
BACKTEST_WALK_FORWARD_TEST_DAYS=63
BACKTEST_MIN_CLOSED_TRADES=3
BACKTEST_MIN_OUT_OF_SAMPLE_DAYS=20
BACKTEST_MIN_WALK_FORWARD_FOLDS=2
BACKTEST_MAX_SYMBOL_CONCENTRATION=0.60
BACKTEST_MIN_BASELINE_ADVANTAGE=0.0
BACKTEST_MAX_OUT_OF_SAMPLE_DRAWDOWN=0.20
LIVE_PREFLIGHT_MAX_BENCHMARK_AGE_DAYS=14
LIVE_PREFLIGHT_MAX_SNAPSHOT_AGE_MINUTES=120
BACKTEST_OUTPUT_DIR=artifacts/backtests

# Momentum strategy settings
TREND_WINDOW=100
EXIT_WINDOW=50
ATR_WINDOW=14
ATR_RISK_BUDGET=100
MAX_ATR_RATIO=0.12

# Mean reversion strategy settings
MEAN_REVERSION_WINDOW=20
MEAN_REVERSION_VOLATILITY_WINDOW=20
MEAN_REVERSION_ENTRY_ZSCORE=-1.0
MEAN_REVERSION_EXIT_ZSCORE=0.0

# Breakout strategy settings
BREAKOUT_ENTRY_WINDOW=55
BREAKOUT_EXIT_WINDOW=20
BREAKOUT_ATR_WINDOW=20

# Politician-copy replay settings
POLITICIAN_COPY_REBALANCE_FREQUENCY=W-FRI
POLITICIAN_COPY_REPLAY_INITIAL_EQUITY=100000
POLITICIAN_COPY_REPLAY_SLIPPAGE_BPS=10

# Safety controls
ALLOW_UNSAFE_DATA_FALLBACK=false
ALLOW_PARTIAL_MARKET_DATA=false
FORCE_EXIT_SYMBOLS=
EMERGENCY_FLATTEN=false
DENY_NEW_ENTRIES=false

# Alerts
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_ON_BLOCKED_ORDERS=true
ALERT_ON_RECONCILIATION_DRIFT=true
ALERT_ON_DRAWDOWN_BREACH=true
ALERT_ON_STALE_DATA=true

# Live rollout guardrail
SAFE_OPEN_ENABLED=false
SAFE_OPEN_START_TIME=09:35
SAFE_OPEN_END_TIME=10:30
